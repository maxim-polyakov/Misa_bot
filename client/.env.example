# Скопируйте в .env перед npm run build (CRA вшивает REACT_APP_* в билд).

# JSON API; также база для публичной ссылки шаринга: https://<этот хост>/share/<chat_id>
# (Django: og:* ботам, редирект людей на FRONTEND из server/.env — WEB_APP_PUBLIC_URL)
REACT_APP_API_URL=https://misaapi.baxic.ru

# Публичный origin веб-клиента (без слэша). Нужен для абсолютных og:image / og:url в index.html после npm run build
# (превью ссылок в Discord/Telegram как у страницы /share/ на API).
REACT_APP_WEB_ORIGIN=https://misa.baxic.ru

# REACT_APP_API_WSS=wss://misaapi.baxic.ru/ws/chat/misa/
