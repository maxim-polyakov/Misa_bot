# Скопируйте в .env перед npm run build (CRA вшивает REACT_APP_* в билд).

# JSON API (чаты, публичный GET /api/chats/<id>/share/ для этой страницы)
REACT_APP_API_URL=https://misaapi.baxic.ru

# WebSocket чата (если используется)
# REACT_APP_API_WSS=wss://misaapi.baxic.ru/ws/chat/misa/

# Превью ссылок в Telegram и др.: HTML с og:* отдаёт Django (share_chat_html);
# на домене веб-клиента nginx должен слать ботов на API — server/deploy/nginx-share-og.conf.example
