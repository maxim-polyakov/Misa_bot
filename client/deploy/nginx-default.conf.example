# Дефолт для веб-домена (misa.baxic.ru): Docker CMD serve → порт 3000.
# Локализованное OG для ботов без Node-прокси — см. server/deploy/nginx-share-og.conf.example.
#
# Подставьте пути к сертификатам и upstream (docker compose: имя сервиса вместо 127.0.0.1).

upstream misa_web {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name misa.baxic.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name misa.baxic.ru;

    ssl_certificate     /etc/letsencrypt/live/misa.baxic.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/misa.baxic.ru/privkey.pem;

    client_max_body_size 20m;

    location / {
        proxy_pass http://misa_web;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout 60s;
    }
}
