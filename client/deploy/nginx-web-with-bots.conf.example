# =============================================================================
# misa.baxic.ru: боты → API (как у вас для /share), обычные клиенты → SPA (serve :3001)
# Включите map один раз в http { }, блок server — в sites-available.
# На API должен быть Django: GET /og/preview/ (см. Front_layer/django_server/og_preview.py)
# =============================================================================

# ----- в http { } -----
# map $http_user_agent $misa_og_bot {
#     default 0;
#     ~*TelegramBot         1;
#     ~*Discordbot          1;
#     ~*facebookexternalhit 1;
#     ~*Facebot             1;
#     ~*Twitterbot          1;
#     ~*LinkedInBot         1;
#     ~*WhatsApp            1;
#     ~*Slackbot            1;
#     ~*vkShare             1;
#     ~*Googlebot           1;
#     ~*bingbot             1;
#     ~*YandexBot           1;
# }

