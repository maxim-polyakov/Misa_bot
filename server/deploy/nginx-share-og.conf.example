# =============================================================================
# Превью ссылок (Open Graph) для https://<WEB>/share/<chat_id>/
# =============================================================================
# Django отдаёт HTML с og:* по GET на API: /share/<chat_id>/ (см. share_chat_html).
# На домене веб-клиента nginx: боты превью → прокси на API, браузеры → SPA.
#
# В http { } — map; в server { } для 443 (misa.baxic.ru) — location /share.
# После правок: sudo nginx -t && sudo systemctl reload nginx
#
# Проверка:
#   curl -sL -A "TelegramBot (like TwitterBot)" "https://misa.baxic.ru/share/CHAT_ID" | grep og:title

# ----- вставить в http { } -----

map $http_user_agent $misa_share_og {
    default 0;
    ~*TelegramBot 1;
    ~*facebookexternalhit 1;
    ~*Facebot 1;
    ~*Twitterbot 1;
    ~*LinkedInBot 1;
    ~*WhatsApp 1;
    ~*Slackbot 1;
    ~*vkShare 1;
    ~*Discordbot 1;
}

# ----- вставить в server { } listen 443; server_name <веб-клиент>; -----
# Замените https://misaapi.baxic.ru на ваш хост API (Django).

# location /share {
#     set $misa_share_backend http://127.0.0.1:3001;
#     set $misa_share_proxy_host $host;
#     if ($misa_share_og = 1) {
#         set $misa_share_backend https://misaapi.baxic.ru;
#         set $misa_share_proxy_host misaapi.baxic.ru;
#     }
#     resolver 8.8.8.8 valid=300s ipv6=off;
#     proxy_ssl_server_name on;
#     proxy_pass $misa_share_backend;
#     proxy_set_header Host $misa_share_proxy_host;
#     proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
# }
#
# Внутри if только set. proxy_pass и proxy_set_header — снаружи if.
