# Скопируйте в .env и заполните значения
# cp .env.example .env

# API (обязательно https для og:image с этого хоста — иначе в мета-тегах будет localhost и Discord не покажет картинку)
API_URL=https://misaapi.baxic.ru
# Явно (если не задано, берётся из API_URL / API_BASE_URL):
# PUBLIC_API_BASE_URL=https://misaapi.baxic.ru

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CLIENT_ID_ANDROID=  # для проверки id_token с Android
# GOOGLE_CLIENT_ID_IOS=      # для проверки id_token с iOS

# URL для OAuth redirect (production: misa.baxic.ru клиент, misaapi.baxic.ru сервер)
API_BASE_URL=https://misaapi.baxic.ru
FRONTEND_URL=https://misa.baxic.ru

# Публичный URL веб-клиента (Open Graph: og:url; og:image — см. server/images/misa.png ниже)
WEB_APP_PUBLIC_URL=https://misa.baxic.ru

# /og/preview/ отдаёт HTML с API: если есть server/images/misa.png (копия client/public/misa.png),
# в og:image подставляется https://<PUBLIC_API_BASE_URL>/images/misa.png — тот же хост, что и HTML (надёжнее для Discord).
# PUBLIC_API_BASE_URL должен быть задан в проде.

# Опционально: полный путь к client/build/index.html на машине API — иначе /og/preview/ отдаёт минимальный HTML (og:* всё равно верны).
# SPA_INDEX_HTML_PATH=/path/to/client/build/index.html

# Cookie misa_locale после POST /api/ui-locale/ (общий для misa.baxic.ru и misaapi.baxic.ru):
# UI_LOCALE_COOKIE_DOMAIN=.baxic.ru
# Для fetch с credentials с веб-домена на API (клиент шлёт POST при смене языка):
# CORS_ALLOWED_ORIGINS=https://misa.baxic.ru

# SMTP для кодов верификации (Docker: smtp-service-misa:1025, локально: localhost:1025)
# SMTP_HOST=smtp-service-misa
# SMTP_PORT=1025

# RAG: Google Search через Serper (https://serper.dev, ~2500 бесплатных запросов/мес)
SERPER_API_KEY=
