# Скопируйте в .env и заполните значения
# cp .env.example .env

# API
API_URL=https://misaapi.baxic.ru

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CLIENT_ID_ANDROID=  # для проверки id_token с Android
# GOOGLE_CLIENT_ID_IOS=      # для проверки id_token с iOS

# URL для OAuth redirect (production: misa.baxic.ru клиент, misaapi.baxic.ru сервер)
API_BASE_URL=https://misaapi.baxic.ru
FRONTEND_URL=https://misa.baxic.ru

# SMTP для кодов верификации (Docker: smtp-service-misa:1025, локально: localhost:1025)
# SMTP_HOST=smtp-service-misa
# SMTP_PORT=1025
